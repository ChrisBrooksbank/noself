{
    "paths": {
        "@/*": ["src/*"],
        "@api/*": ["src/api/*"],
        "@core/*": ["src/core/*"],
        "@utils/*": ["src/utils/*"],
        "@config/*": ["src/config/*"],
        "@types/*": ["src/types/*"]
    },
    "entry": [
        "src/api/index.ts",
        "src/core/index.ts",
        "src/types/index.ts",
        "src/utils/index.ts",
        "src/config/index.ts",
        "src/content/concepts/index.ts",
        "src/content/meditations/index.ts",
        "src/content/prompts/index.ts"
    ]
}
