{
    "name": "noself",
    "private": true,
    "version": "0.2.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "typecheck": "tsc -b --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "knip": "knip",
        "check": "npm run typecheck && npm run lint && npm run format:check && npm run knip",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "deploy": "npm run check && npm run test:run && npm run build && netlify deploy --prod",
        "prepare": "husky"
    },
    "dependencies": {
        "yaml": "^2.8.2",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.21.0",
        "@types/node": "^22.13.5",
        "@vitest/coverage-v8": "^3.0.7",
        "eslint": "^9.21.0",
        "eslint-config-prettier": "^10.0.1",
        "globals": "^16.0.0",
        "husky": "^9.1.7",
        "jsdom": "^26.0.0",
        "knip": "^5.44.0",
        "lint-staged": "^15.4.3",
        "prettier": "^3.5.3",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.25.0",
        "vite": "^6.2.0",
        "vite-plugin-pwa": "^0.21.1",
        "vitest": "^3.0.7"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml,css,html}": [
            "prettier --write"
        ]
    }
}
